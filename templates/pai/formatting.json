{
  "font": "Times New Roman",
  "base_font_size": 12,
  "text_color": "#000",

  "docx_font": "Calibri",
  "docx_table_style": "Light Grid Accent 1",
  "html_max_width": "1280px",

  "status_colors": {
    "valid": "#008000",
    "warning": "#FFA500",
    "invalid": "#FF0000"
  },

  "hierarchy_levels": ["Full Scales", "Subscales"],
  "fallback_category": "Other Scales",

  "chart_colors": {
    "Validity Scales": "#555555",
    "Clinical Scales": "#1A5276",
    "Treatment Consideration Scales": "#922B21",
    "Interpersonal Scales": "#117A65"
  },
  "validity_chart_colors": {
    "Response Consistency": "#555555",
    "Negative Distortion": "#922B21",
    "Positive Distortion": "#1A5276"
  },
  "domain_definitions": {
    "Somatic/Anxiety Disorders": {
      "scales": ["SOM", "ANX", "ARD"],
      "color": "#922B21"
    },
    "Mood/Affective Disorders": {
      "scales": ["DEP", "MAN", "SUI"],
      "color": "#1A5276"
    },
    "Psychotic/Personality Features": {
      "scales": ["PAR", "SCZ", "BOR", "ANT"],
      "color": "#4A235A"
    },
    "Substance Use": {
      "scales": ["ALC", "DRG"],
      "color": "#935116"
    },
    "Treatment/Interpersonal": {
      "scales": ["AGG", "STR", "NON", "RXR", "DOM", "WRM"],
      "color": "#117A65"
    }
  },

  "chart": {
    "chart_font_size": 16,
    "chart_png_font_scale": 1.3,
    "y_min": 25,
    "y_max": 120,
    "y_interval": 10,
    "reference_lines": [
      {"value": 59, "label": "59T", "style": "dashed", "color": "#FFA500"},
      {"value": 69, "label": "69T", "style": "dashed", "color": "#FF0000"}
    ],
    "line_styles": {},
    "height": "700px",
    "symbol_size_normal": 8,
    "symbol_size_elevated": 12,
    "line_width": 2.5,
    "validity_line_width": 3.0,
    "grid": {
      "combined": {"left": "8%", "right": "5%", "bottom": "20%", "top": "10%"},
      "domain": {"left": "8%", "right": "5%", "bottom": "15%", "top": "10%"},
      "validity": {"left": "10%", "right": "8%", "bottom": "15%", "top": "10%"}
    },
    "plot_bands": [30, 50, 60, 70, 90]
  },

  "validity_subcategories": {
    "Response Consistency": ["ICN", "INF"],
    "Negative Distortion": ["NIM"],
    "Positive Distortion": ["PIM"]
  }
}
